    try {
      await eliminarCliente(id);

      await cargarClientes();
    } catch (error) {
      console.error(error);
    }
  }

  function handleEditar(cliente) {
    alert(`Editar: ${cliente.nombre}`);

    setClienteEditando(cliente);

    setNombre(cliente.nombre || "");
    setTelefono(cliente.telefono || "");
